# Tempo AI — Environment Variables
# Copy this file to .env.local and fill in your values.
# You need at least ONE of the API keys below.

# ─── Option A: Anthropic (Claude) ───────────────────────────────────────
# Get your key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional: Model identifier (default: claude-sonnet-4-20250514)
# Options: claude-sonnet-4-20250514, claude-3-5-haiku-20241022, etc.
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ─── Option B: OpenRouter ───────────────────────────────────────────────
# Get your key at https://openrouter.ai/keys
# OPENROUTER_API_KEY=

# Optional: Model identifier (default: openai/gpt-4o-mini)
# See available models at https://openrouter.ai/models
# OPENROUTER_MODEL=openai/gpt-4o-mini
